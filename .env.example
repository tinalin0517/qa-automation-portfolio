# Anthropic API key for local development only. Do not commit real keys.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: OpenSearch demo integration. Use mock/manual log input by default.
OPENSEARCH_HOST=opensearch-demo.example.com
OPENSEARCH_COOKIE=

# Optional: demo code zip paths for codeRefs feature
PAYMENT_CODE_ZIP=sample-payment-service.zip
PRICING_CODE_ZIP=sample-pricing-service.zip

# Optional: SSO provider names for local-only cookie refresh demo
# OPENSEARCH_SSO_PROVIDER=your-sso-provider-name
# OPENSEARCH_SSO_AD_BUTTON=Your-AD-Button-Label

# Flask settings
FLASK_DEBUG=false
PORT=5001
